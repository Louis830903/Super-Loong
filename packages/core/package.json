{
  "name": "@super-agent/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --dts --external ssh2 --external cpu-features",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "chokidar": "^4.0.0",
    "cron-parser": "^5.5.0",
    "eventemitter3": "^5.0.1",
    "gray-matter": "^4.0.3",
    "openai": "^4.80.0",
    "pino": "^9.6.0",
    "sql.js": "^1.14.1",
    "uuid": "^11.1.0",
    "zod": "^3.24.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "optionalDependencies": {
    "ssh2": "^1.16.0",
    "playwright": "^1.52.0",
    "xlsx": "^0.18.5",
    "diff": "^7.0.0",
    "pdf-parse": "^1.1.1",
    "qrcode": "^1.5.4",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/uuid": "^10.0.0",
    "rimraf": "^6.0.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
