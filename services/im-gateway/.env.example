# Super Agent IM Gateway
# 基于 Hermes 平台适配器的 IM 网关微服务

# ====== 必填 ======
# Super Agent API 连接配置
SUPER_AGENT_API_URL=http://localhost:3001
SUPER_AGENT_API_KEY=
DEFAULT_AGENT_ID=

# Hermes 仓库路径 (默认为相对路径 ../../../hermes-agent)
# HERMES_PATH=/path/to/hermes-agent

# IM Gateway 服务端口
IM_GATEWAY_PORT=3002

# ====== 企业微信 (WeChat Work) ======
# 推荐配置 corpid + corpsecret 实现 token 自动刷新
# WECOM_CORPID=
# WECOM_CORPSECRET=
# WECOM_AGENTID=1000002
# 兼容旧配置 (直接传入 token, 2小时后过期)
# WECOM_BOT_ID=
# WECOM_SECRET=
# WECOM_WEBSOCKET_URL=

# ====== 飞书 (Feishu/Lark) ======
# 推荐配置 app_id + app_secret 实现 token 自动刷新
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=

# ====== 钉钉 (DingTalk) ======
# 推荐配置 appkey + appsecret 实现 token 自动刷新
# DINGTALK_CLIENT_ID=
# DINGTALK_CLIENT_SECRET=
# DINGTALK_AGENT_ID=

# ====== 微信 (WeChat) ======
# WEIXIN_ACCOUNT_ID=
# WEIXIN_TOKEN=

# ====== Telegram ======
# TELEGRAM_BOT_TOKEN=

# ====== Discord ======
# DISCORD_BOT_TOKEN=

# ====== Slack ======
# SLACK_BOT_TOKEN=

# ====== 微信 ClawBot (via WeClaw) ======
# WeClaw 桥接工具地址（WeClaw 启动后默认监听 18011）
# WECLAW_ENABLED=true
# WECLAW_API_URL=http://127.0.0.1:18011
# 网关对外地址（用于将 MEDIA: 标记转为可下载的 HTTP URL）
# GATEWAY_PUBLIC_URL=http://127.0.0.1:8642
# 媒体文件存储目录
# MEDIA_SERVE_DIR=.media
